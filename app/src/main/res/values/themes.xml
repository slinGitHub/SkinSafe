<resources>
    <style name="Theme.SkinSafe" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- ... andere Farben ... -->

        <!-- Overflow-Menü Style überschreiben -->
        <item name="popupMenuStyle">@style/Widget.SkinSafe.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.SkinSafe.PopupMenu</item>
    </style>

    <style name="Widget.SkinSafe.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@color/colorBackgroundNotifications</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.CheckInset.Light" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorPrimary">#602D58</item>
<!--        <item name="colorPrimaryVariant">#4A1F42</item>-->
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Button-Style -->
<!--        <item name="buttonStyle">@style/CustomButton</item>-->

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Status Bar -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">true</item> <!-- schwarze Icons -->

        <!-- Deaktiviere Monet -->
        <item name="dynamicColorThemeOverlay">@null</item>

    </style>

</resources>
