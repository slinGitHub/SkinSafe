<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Toolbar oben -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:elevation="12dp"
        android:background="@color/colorBackgroundStatusNavi"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
        app:title=" SKIN SAFE"
        android:layout_gravity="top"
        app:titleTextAppearance="@style/ToolbarTitleBold"
        android:titleTextColor="@color/DarkColor1"
        app:theme="@style/ThemeOverlay.MaterialComponents.ActionBar"/>

    <!-- Hauptinhalt: Ein vertikales Layout mit ScrollView -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:background="@color/colorBackground"
        android:elevation="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp">

        <!-- ScrollView, in dem die dynamisch erzeugten Bildbereiche platziert werden -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/imageScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="300dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"> <!-- Höhe des Bottom Sheets, nicht berechnet!! -->

            <LinearLayout
                android:id="@+id/imageContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>


<!--    <ImageButton-->
<!--        android:id="@+id/addPointButton"-->
<!--        android:layout_width="45dp"-->
<!--        android:layout_height="45dp"-->
<!--        android:layout_margin="20dp"-->
<!--        android:elevation="4dp"-->
<!--        android:background="@drawable/circular_button"-->
<!--        android:src="@android:drawable/ic_input_add"-->
<!--        app:tint="@android:color/white"-->
<!--        android:layout_gravity="bottom|end"/>-->



    <!-- Bottom Sheet Layout für die Punktdetails -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp"
        android:elevation="8dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        android:visibility="visible"
        android:clipChildren="false"
        android:clipToPadding="false">
        <!-- app:behavior_peekHeight="120dp" -->

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_sheet_handle"/>

    <!-- Button zum Löschen des aktuell bearbeiteten Punktes -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <TextView
                android:id="@+id/tvCircleNumber"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/DarkColor1"
                android:background="@drawable/bg_circle"/>

            <!-- Platzhalter, der alles dazwischen füllt -->
            <TextView
                android:id="@+id/tvSpacerText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/days_old"
                android:textSize="16sp"
                android:textColor="@color/colorSecondaryBlackText" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnMovePoint"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle"
                android:src="@drawable/ic_edit_location"
                android:scaleType="centerInside"
                android:contentDescription="@string/description_move_point"
                android:padding="10dp"
                android:layout_marginRight="8dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnDeletePoint"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_circle"
                android:src="@drawable/ic_delete"
                android:scaleType="centerInside"
                android:contentDescription="@string/description_delete"
                android:padding="10dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- DATUM -->
        <com.google.android.material.textfield.TextInputLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/created_on"
            android:layout_margin="4dp"
            app:startIconTint="?attr/colorOnSurfaceVariant"
            app:boxStrokeColor="?attr/colorPrimary"
            app:boxStrokeWidth="1dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tvTimestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_date_found"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:inputType="date"
                android:focusable="false"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Vote your experience -->
        <!-- TRAFFIC LIGHT RATING -->
        <FrameLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp">

            <!-- TextInputLayout als Hintergrund für Linie und Label -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/rate_your_experience"
                app:boxStrokeColor="?attr/colorPrimary"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:hintEnabled="true"
                app:expandedHintEnabled="false"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/place_holder_rate_your_exp"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:textColor="@android:color/transparent"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Traffic Light Buttons darüber -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Green (Good) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ratingBtnGreen"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:icon="@drawable/ic_circle"
                    app:iconTint="@color/circleBackgroundGreen"
                    app:iconGravity="textStart"
                    app:iconSize="40dp"
                    app:iconPadding="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cornerRadius="28dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <!-- Yellow (Neutral) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ratingBtnYellow"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    app:icon="@drawable/ic_circle"
                    app:iconTint="@color/circleBackgroundYellow"
                    app:iconGravity="textStart"
                    app:iconSize="40dp"
                    app:iconPadding="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cornerRadius="28dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <!-- Red (Bad) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ratingBtnRed"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_circle"
                    app:iconTint="@color/circleBackgroundRed"
                    app:iconGravity="textStart"
                    app:iconSize="40dp"
                    app:iconPadding="0dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:cornerRadius="28dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

            </LinearLayout>

        </FrameLayout>

        <!-- TEXTFIELD FOR NOTES-->
        <com.google.android.material.textfield.TextInputLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/notes"
            android:layout_margin="4dp"
            app:startIconTint="?attr/colorOnSurfaceVariant"
            app:boxStrokeColor="?attr/colorPrimary"
            app:boxStrokeWidth="1dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/pointNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/add_your_notes_here"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:inputType="textMultiLine|textNoSuggestions"
                android:minLines="2"
                android:gravity="top|start"
                android:focusable="true"
                android:focusableInTouchMode="true"/>
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Floating Action Button für "Punkte setzen"-->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addPointButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:contentDescription="@string/set_points"
        android:elevation="4dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/DarkColor1"
        app:tint="@color/colorBackground"
        android:layout_gravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
